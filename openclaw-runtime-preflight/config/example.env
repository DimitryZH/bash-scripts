# Example configuration for openclaw_container_runtime_preflight.sh
# Copy this file, adjust values for your environment, and pass it with --config.
# Do not place secrets or gateway tokens in this file.

MODE=basic

SERVICE_NAME=openclaw.service
CONTAINER_NAME=openclaw-gateway
BASE_URL=http://127.0.0.1:8080

STATE_MOUNT=/var/lib/openclaw
STATE_DIR=/var/lib/openclaw/state
WORKSPACE_DIR=/var/lib/openclaw/workspace

TOKEN_FILE=/run/openclaw/secrets/OPENCLAW_GATEWAY_TOKEN
MODEL_NAME=openclaw
CONTROL_UI_PATTERN=openclaw-control-ui

CURL_CONNECT_TIMEOUT=3
CURL_MAX_TIME=15
CHAT_MAX_TIME=120

# GCP DevBox Toolkit configuration
#
# Copy this file to a local untracked path, replace placeholders, and use:
#   ./scripts/<script>.sh --config /path/to/devbox.env
#
# The scripts parse an approved key list and do not execute this file as shell
# code. Do not store credentials, private keys, access tokens, or secrets here.

# Google Cloud target
PROJECT_ID=REPLACE_WITH_GCP_PROJECT_ID
REGION=us-central1
ZONE=us-central1-a

# Compute Engine VM
VM_NAME=ai-devbox-01
MACHINE_TYPE=e2-standard-2
BOOT_DISK_SIZE_GB=80
BOOT_DISK_TYPE=pd-balanced
IMAGE_FAMILY=ubuntu-2404-lts-amd64
IMAGE_PROJECT=ubuntu-os-cloud

# Network
NETWORK=default
SUBNET=default
NETWORK_TAGS=devbox-iap-ssh

# Secure default: no external IP.
# A private VM needs Cloud NAT or another approved outbound path for internet
# access. Set true only when the design explicitly requires an ephemeral
# external IP and direct public SSH remains blocked.
CREATE_EXTERNAL_IP=false

# Existing firewall rule names. The toolkit validates these rules but does not
# create them.
IAP_ALLOW_FIREWALL_RULE=devbox-allow-iap-ssh
PUBLIC_SSH_DENY_FIREWALL_RULE=devbox-deny-public-ssh
REQUIRE_IAP_FIREWALL_RULE=true
REQUIRE_PUBLIC_SSH_DENY_RULE=true

# Identity and instance metadata
ENABLE_OS_LOGIN=true
NO_SERVICE_ACCOUNT=true
LABELS=purpose=devbox,managed-by=bash

# Connection
TUNNEL_THROUGH_IAP=true

# In-VM validation thresholds
MIN_CPU_COUNT=2
MIN_MEMORY_GB=6
MIN_FREE_DISK_GB=20
REQUIRED_TOOLS=git,docker,dotnet,curl,jq,bash,unzip
OPTIONAL_BROWSER_CHECK=true

# Evidence collection
EVIDENCE_OUTPUT_DIR=./devbox-evidence
VALIDATION_LOG_DIR=
MAX_LOG_LINES=200
INCLUDE_DOCKER_DETAILS=true
INCLUDE_GIT_STATUS=true

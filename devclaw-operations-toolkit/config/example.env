# DevClaw Operations Toolkit configuration
#
# Copy this file to a local path and adjust it for the target host.
# The parser accepts only the keys listed below and does not execute shell code.
# Do not store OPENCLAW_GATEWAY_TOKEN or any other secret in this file.

# Optional explicit package path. Leave empty to use discovery.
DEVCLAW_PACKAGE_DIR=

# Root searched for:
# */node_modules/@laurentenhoor/devclaw
DEVCLAW_PACKAGE_SEARCH_ROOT=/home/devclaw-svc/.openclaw/npm/projects

# DevClaw workspace/state location.
DEVCLAW_STATE_DIR=/home/devclaw-svc/.openclaw/workspace/devclaw

# Runtime identity and trusted OpenClaw gateway environment file.
DEVCLAW_SERVICE_USER=devclaw-svc
DEVCLAW_GATEWAY_ENV_FILE=/var/lib/devclaw/gateway/openclaw-gateway.env
OPENCLAW_BIN=/usr/local/bin/openclaw

# Required only when INCLUDE_TASK_STATUS=true.
PROJECT_SLUG=REPLACE_WITH_PROJECT_SLUG

# all = source and state inspection
# source = compiled package inspection only
# state = workspace/state inspection only
MODE=all

MAX_RESULTS=120
TASK_TIMEOUT_SECONDS=120

EXACT_ERROR="Execution prevented because the circuit breaker is open"

# Disabled by default because this probe can invoke an AI model and consume tokens.
INCLUDE_TASK_STATUS=false
